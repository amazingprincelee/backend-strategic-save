# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/strategic-crypto-save

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Email Configuration (for email verification and notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@strategiccryptosave.com

# Blockchain Configuration
RPC_URL=https://sepolia.infura.io/v3/your-infura-project-id
CONTRACT_ADDRESS=0x727494Fc6ff540ce2d9D30dEFF2e631e912fC288
PRIVATE_KEY=your-private-key-for-event-listening-only

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Socket.IO / CORS Configuration (Vite default port is 5173)
CLIENT_URL=http://localhost:5173

# Proxy Configuration (optional — uncomment if exchange APIs time out in your region)
# HTTPS_PROXY=http://127.0.0.1:7890
# SOCKS_PROXY=socks5://127.0.0.1:1080